// For format details, see https://aka.ms/devcontainer.json.
{
	"name": "Python 3",
	"build": {
		"context": "..",
		"dockerfile": "Dockerfile"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance"
			]
		}
	},
	"forwardPorts": [5000],
	"postCreateCommand": "python -m pip install -r requirements.txt",
	"postStartCommand": "echo 'Use the VS Code task \"Run Flask\" or run: flask --app app run --host 0.0.0.0'"
}
